{
  "name": "Employee",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do colaborador"
    },
    "role": {
      "type": "string",
      "enum": [
        "ENFERMEIRA",
        "ENFERMEIRO",
        "TEC.ENF",
        "AUX.ENF",
        "RES.TECNICA",
        "SUPERVIS\u00c3O"
      ],
      "description": "Fun\u00e7\u00e3o do colaborador"
    },
    "coren": {
      "type": "string",
      "description": "N\u00famero COREN"
    },
    "shift_type": {
      "type": "string",
      "enum": [
        "diurno_a",
        "diurno_b",
        "noturno_a",
        "noturno_b"
      ],
      "description": "Tipo de turno"
    },
    "work_hours": {
      "type": "string",
      "description": "Hor\u00e1rio de trabalho (ex: 07:00 as 19:00)"
    },
    "sector": {
      "type": "string",
      "description": "Setor de atua\u00e7\u00e3o"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "on_leave"
      ],
      "default": "active",
      "description": "Status do colaborador"
    },
    "cycle": {
      "type": "string",
      "enum": [
        "par",
        "impar"
      ],
      "description": "Ciclo da escala 12x36"
    },
    "contract_type": {
      "type": "string",
      "description": "Tipo de contrato (Estatut\u00e1rio, CLT, etc.)"
    }
  },
  "required": [
    "name",
    "role",
    "shift_type"
  ]
}